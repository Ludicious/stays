MYSQL_HOST=your-hostinger-mysql-host
MYSQL_USER=your-db-user
MYSQL_PASSWORD=your-db-password
MYSQL_DATABASE=your-db-name
MYSQL_PORT=3306

# Optional — identifies this deployment in the UI.
# Set to a short label (e.g. AR) to show [AR] prefix in page titles and a
# subtle footer badge. Leave unset (or set to "Stays") for the default instance.
# INSTANCE_NAME=
